{
  "name": "keyboard-shortcuts-library",
  "version": "1.1.0",
  "description": "A lightweight, flexible JavaScript library for creating and managing custom keyboard shortcuts in web applications.",
  "main": "./dist/keyboard-shortcuts.js",
  "module": "./dist/keyboard-shortcuts.mjs",
  "types": "./dist/keyboard-shortcuts.d.ts",
  "unpkg": "./dist/keyboard-shortcuts.global.js",
  "exports": {
    ".": {
      "types": "./dist/keyboard-shortcuts.d.ts",
      "import": "./dist/keyboard-shortcuts.mjs",
      "require": "./dist/keyboard-shortcuts.js",
      "default": "./dist/keyboard-shortcuts.global.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "keyboard",
    "shortcut",
    "shortcuts",
    "hotkey",
    "hotkeys",
    "keybinding",
    "keybindings"
  ],
  "author": "Utkarsh Priyadarshi",
  "license": "GPL-3.0-or-later",
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.0",
    "happy-dom": "^20.10.2",
    "prettier": "^3.2.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
